<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fund_transfer_tree" model="ir.ui.view">
        <field name="name">fund.transfer.tree</field>
        <field name="model">fund.transfer</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'draft'"
                  decoration-warning="state in ('submitted','gm_approval','md_approval')"
                  decoration-success="state == 'approved'"
                  decoration-muted="state in ('rejected','cancelled')">
                <field name="transfer_number"/>
                <field name="request_date"/>
                <field name="source_budget_line_id"/>
                <field name="destination_budget_line_id"/>
                <field name="amount" widget="monetary"/>
                <field name="state"/>
                <field name="requested_by"/>
            </tree>
        </field>
    </record>
    <record id="view_fund_transfer_form" model="ir.ui.view">
        <field name="name">fund.transfer.form</field>
        <field name="model">fund.transfer</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit" type="object"
                            class="btn-primary"
                            invisible="state not in ('draft',)"
                            groups="group_fund_user,group_fund_administrator"/>
                    <button name="action_gm_approve" string="GM Approve" type="object"
                            class="btn-success"
                            invisible="state != 'submitted'"
                            groups="group_gm_approver,group_fund_administrator"/>
                    <button name="action_reject" string="GM Reject" type="object"
                            class="btn-danger"
                            invisible="state != 'submitted'"
                            groups="group_gm_approver,group_fund_administrator"/>
                    <button name="action_md_approve" string="MD Approve" type="object"
                            class="btn-success"
                            invisible="state != 'gm_approval'"
                            groups="group_md_approver,group_fund_administrator"/>
                    <button name="action_reject" string="MD Reject" type="object"
                            class="btn-danger"
                            invisible="state != 'gm_approval'"
                            groups="group_md_approver,group_fund_administrator"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            class="btn-secondary"
                            invisible="state not in ('draft', 'submitted', 'gm_approval')"
                            groups="group_fund_administrator"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="transfer_number" readonly="1"/>
                        <field name="state" readonly="1"/>
                    </group>
                    <group>
                        <field name="request_date"/>
                        <field name="requested_by"/>
                        <field name="source_budget_line_id"/>
                        <field name="destination_budget_line_id"/>
                        <field name="amount" widget="monetary"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="reason"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_fund_transfer_search" model="ir.ui.view">
        <field name="name">fund.transfer.search</field>
        <field name="model">fund.transfer</field>
        <field name="arch" type="xml">
            <search>
                <field name="transfer_number"/>
                <field name="state"/>
                <field name="source_budget_line_id"/>
                <field name="destination_budget_line_id"/>
                <field name="requested_by"/>
                <field name="request_date"/>
            </search>
        </field>
    </record>
    <record id="action_fund_transfer" model="ir.actions.act_window">
        <field name="name">Transfers</field>
        <field name="res_model">fund.transfer</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_fund_transfer_search"/>
    </record>
</odoo>
