<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fund_approval_rule_tree" model="ir.ui.view">
        <field name="name">fund.approval.rule.tree</field>
        <field name="model">fund.approval.rule</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="request_type"/>
                <field name="company_id"/>
                <field name="min_amount" widget="monetary"/>
                <field name="max_amount" widget="monetary"/>
                <field name="gm_required"/>
                <field name="md_required"/>
                <field name="sequence"/>
                <field name="active"/>
            </tree>
        </field>
    </record>
    <record id="view_fund_approval_rule_form" model="ir.ui.view">
        <field name="name">fund.approval.rule.form</field>
        <field name="model">fund.approval.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                        <field name="company_id"/>
                        <field name="request_type"/>
                    </group>
                    <group>
                        <field name="min_amount" widget="monetary"/>
                        <field name="max_amount" widget="monetary"/>
                        <field name="gm_required"/>
                        <field name="md_required"/>
                        <field name="sequence"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_fund_approval_rule" model="ir.actions.act_window">
        <field name="name">Approval Rules</field>
        <field name="res_model">fund.approval.rule</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_fund_approval_rule" name="Approval Rules" parent="menu_fund_configuration" action="action_fund_approval_rule" groups="fund.group_fund_administrator"/>
</odoo>
