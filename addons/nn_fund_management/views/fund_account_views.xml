<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fund_account_tree" model="ir.ui.view">
        <field name="name">fund.account.tree</field>
        <field name="model">fund.account</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'draft'"
                  decoration-success="state == 'confirmed'"
                  decoration-danger="state == 'cancelled'">
                <field name="name"/>
                <field name="account_type"/>
                <field name="company_id"/>
                <field name="currency_id"/>
                <field name="total_received" widget="monetary"/>
                <field name="unassigned_balance" widget="monetary"/>
                <field name="held_amount" widget="monetary"/>
                <field name="assigned_amount" widget="monetary"/>
            </tree>
        </field>
    </record>
    <record id="view_fund_account_form" model="ir.ui.view">
        <field name="name">fund.account.form</field>
        <field name="model">fund.account</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="account_type"/>
                        <field name="company_id"/>
                        <field name="currency_id"/>
                    </group>
                    <group string="Balances" name="balances">
                        <field name="total_received" readonly="1"/>
                        <field name="unassigned_balance" readonly="1"/>
                        <field name="held_amount" readonly="1"/>
                        <field name="assigned_amount" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_fund_account_search" model="ir.ui.view">
        <field name="name">fund.account.search</field>
        <field name="model">fund.account</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="account_type"/>
                <field name="company_id"/>
                <filter string="Active" domain="[('active','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Account Type" context="{'group_by':'account_type'}"/>
                    <filter string="Company" context="{'group_by':'company_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="action_fund_account" model="ir.actions.act_window">
        <field name="name">Fund Accounts</field>
        <field name="res_model">fund.account</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="search_view_id" ref="view_fund_account_search"/>
    </record>
</odoo>
