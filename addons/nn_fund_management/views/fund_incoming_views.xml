<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fund_incoming_tree" model="ir.ui.view">
        <field name="name">fund.incoming.tree</field>
        <field name="model">fund.incoming</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date"/>
                <field name="fund_account_id"/>
                <field name="amount"/>
                <field name="transaction_reference"/>
                <field name="partner_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>
    <record id="view_fund_incoming_form" model="ir.ui.view">
        <field name="name">fund.incoming.form</field>
        <field name="model">fund.incoming</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            class="btn-primary"
                            attrs="{'invisible':[('state','!=','draft')]}"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="fund_account_id"/>
                        <field name="date"/>
                        <field name="amount"/>
                        <field name="transaction_reference"/>
                        <field name="partner_id"/>
                    </group>
                    <group>
                        <field name="description"/>
                        <field name="attachment"/>
                        <field name="company_id"/>
                        <field name="currency_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_fund_incoming" model="ir.actions.act_window">
        <field name="name">Incoming Funds</field>
        <field name="res_model">fund.incoming</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
