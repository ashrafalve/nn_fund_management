<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fund_budget_line_kanban" model="ir.ui.view">
        <field name="name">fund.budget.line.kanban</field>
        <field name="model">fund.budget.line</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <span>
                                    <field name="target_type"/>
                                </span>
                                <div class="o_kanban_balanced">
                                    <div>
                                        <t t-if="record.target_type.raw_value == 'project'">Project</t>
                                        <t t-else="">Expense Head</t>
                                    </div>
                                    <div class="text-muted">Available</div>
                                    <div class="text-primary">
                                        <field name="available" widget="monetary"/>
                                    </div>
                                </div>
                                <div class="o_kanban_balanced">
                                    <div>
                                        <t t-if="record.target_type.raw_value == 'project'">Total Allocated</t>
                                        <t t-else="">Total Allocated</t>
                                    </div>
                                    <div class="text-muted">Spent</div>
                                    <div>
                                        <field name="total_spent" widget="monetary"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_fund_budget_line_tree" model="ir.ui.view">
        <field name="name">fund.budget.line.tree</field>
        <field name="model">fund.budget.line</field>
        <field name="arch" type="xml">
            <tree decoration-warning="available &lt; 0" decoration-success="available &gt;= 0">
                <field name="name"/>
                <field name="target_type"/>
                <field name="project_id"/>
                <field name="expense_head_id"/>
                <field name="company_id"/>
                <field name="currency_id"/>
                <field name="total_allocated" widget="monetary"/>
                <field name="available" widget="monetary"/>
                <field name="requisition_hold" widget="monetary"/>
                <field name="transfer_hold" widget="monetary"/>
                <field name="approved_unspent" widget="monetary"/>
                <field name="total_spent" widget="monetary"/>
                <field name="incoming_transfers" widget="monetary"/>
                <field name="outgoing_transfers" widget="monetary"/>
            </tree>
        </field>
    </record>

    <record id="view_fund_budget_line_form" model="ir.ui.view">
        <field name="name">fund.budget.line.form</field>
        <field name="model">fund.budget.line</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="target_type"/>
                        <field name="project_id" attrs="{'invisible':[('target_type','!=','project')]}"/>
                        <field name="expense_head_id" attrs="{'invisible':[('target_type','!=','expense_head')]}"/>
                        <field name="company_id"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group string="Balances" name="balances">
                        <field name="total_allocated" readonly="1"/>
                        <field name="available" readonly="1"/>
                        <field name="requisition_hold" readonly="1"/>
                        <field name="transfer_hold" readonly="1"/>
                        <field name="approved_unspent" readonly="1"/>
                        <field name="total_spent" readonly="1"/>
                        <field name="incoming_transfers" readonly="1"/>
                        <field name="outgoing_transfers" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fund_budget_line_search" model="ir.ui.view">
        <field name="name">fund.budget.line.search</field>
        <field name="model">fund.budget.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="target_type"/>
                <field name="project_id"/>
                <field name="expense_head_id"/>
                <field name="company_id"/>
                <filter string="Available &gt; 0" domain="[('available','&gt;',0)]"/>
                <group expand="0" string="Group By">
                    <filter string="Target Type" context="{'group_by':'target_type'}"/>
                    <filter string="Company" context="{'group_by':'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_fund_budget_line" model="ir.actions.act_window">
        <field name="name">Budget Lines</field>
        <field name="res_model">fund.budget.line</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_fund_budget_line_search"/>
    </record>
</odoo>
