<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Multi-company security for models with company_id -->
        <record id="rule_fund_account_multi_company" model="ir.rule">
            <field name="name">Fund Account: Multi-Company</field>
            <field name="model_id" ref="model_fund_account"/>
            <field name="domain_force">[('company_id','in',company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user')), (4, ref('fund.group_fund_administrator'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
